---
import LayoutG from "../layouts/LayoutG.astro";

const title = "Galería";
const description = "Explora nuestra colección de imágenes destacadas.";
const images = [
  "/assets/trabajador.jpg",
  "/assets/Gass.jpg",
  "/assets/Instalacion.jpg",
  "/assets/eolica.jpg",
  "/assets/industria.jpg",
  "/assets/Grua.jpg"
];
---

<LayoutG title={title}>
  <!-- Encabezado -->
  <header class="header">
    <h1>{title}</h1>
    <p>{description}</p>
  </header>

  <main>
    <!-- Galería de Imágenes -->
    <section class="gallery">
      {images.map((img) => (
        <div class="gallery-item">
          <img src={img} alt="Imagen de la galería" loading="lazy" />
        </div>
      ))}
    </section>
  </main>
</LayoutG>

<style>
  /* Reset global para evitar márgenes blancos */
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html, body {
    width: 100%;
    height: 100%;
    overflow-x: hidden;
    background-color: #fff; /* Evita posibles fondos grises en algunas pantallas */
  }

  .header {
    text-align: center;
    padding: 60px 20px;
    background: linear-gradient(to right, #00A152, #006837);
    color: white;
  }
  

  .header h1 {
    font-size: 80px;
    margin-bottom: 15px;
  }

  .header p {
    font-size: 30px;
    line-height: 1.6;
  }

  /* Galería con 2 imágenes por fila */
  .gallery {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 15px;
    padding: 20px;
    max-width: 1200px;
    margin: auto;
  }

  .gallery-item {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .gallery img {
    width: 100%;
    height: auto;
    border-radius: 10px;
    box-shadow: 2px 2px 10px rgba(0, 0, 0, 0.2);
    transition: transform 0.3s ease-in-out;
  }

  .gallery img:hover {
    transform: scale(1.05);
  }

  /* Para móviles: 1 imagen por fila */
  @media (max-width: 768px) {
    .gallery {
      grid-template-columns: 1fr;
    }
  }
</style>
